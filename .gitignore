# --- PHP / Composer ---
vendor/
composer.lock              # commituj tylko, gdy faktycznie chcesz „zamrozić” wersje
composer.phar              # lokalny composer phar

# --- Node / Vite ---
node_modules/
public/hot                 # plik Hot Module Reload
# public/build               # artefakty Vite (prod generujesz w CI)

# --- SEO: mapa i robots generowane przez app/Http/Controllers/SeoController.php (nie trzymaj kopii statycznych) ---
/public/robots.txt
/public/sitemap.xml

# --- Laravel ---
storage/*
!storage/.gitignore        # zachowaj puste foldery
bootstrap/cache/*
!.docker                    # własne skrypty/konfiguracje dla Dockera

# --- Env & Secrets ---
.env                       # lokalny
.env.*.enc                 # zaszyfrowane (laravel env:encrypt)
.env.*.json                # dla direnv/dotenv-vault

# --- Database Backups ---
mysql-backups/

# --- Docker Overrides (lokalne konfiguracje) ---
docker-compose.override.yml

# --- IDE / OS ---
.idea/
.vscode/
.DS_Store
thumbs.db

# Windows / WSL: znaczniki strefy (NTFS ADS) przy kopiowaniu z Internetu — nie commitować
*Zone.Identifier
*:Zone.Identifier
**/*Zone.Identifier
**/*:Zone.Identifier

storage/app/publicpublic/robots.txt
.env
public/storage
