APP_NAME="Platforma Nowoczesnej Edukacji"
APP_ENV=local
APP_KEY=base64:B7IgNonVRRJGdXEFesZAFB0bNZ85NfJ0+yda7wFZ4gk=
APP_DEBUG=true

# → ustawienia regionalne
APP_LOCALE=pl
APP_FALLBACK_LOCALE=pl
APP_FAKER_LOCALE=pl_PL

# strefa czasowa Polski
APP_TIMEZONE=Europe/Warsaw

# Sesja MySQL — UTC dla wspólnej bazy pneadm (form_orders.order_date = TIMESTAMP UTC)
DB_TIMEZONE=+00:00

APP_URL=http://localhost

# SEO: domyślnie indeksowanie WŁĄCZONE. Na stagingu / lokalnie bez indeksu ustaw: SEO_BLOCK_INDEXING=true
# Na produkcji (pnedu.pl): APP_URL=https://pnedu.pl oraz opcjonalnie:
# SEO_DEFAULT_DESCRIPTION=...
# SEO_OG_IMAGE=https://pnedu.pl/logo-pne.png
# SEO_BLOCK_INDEXING=false

# Strona główna (Faza 6): krótki cache HTML dla gości — CDN / LiteSpeed
# HOMEPAGE_PAGE_CACHE_MAX_AGE=60
# HOMEPAGE_PAGE_CACHE_STALE=120

# Panel (Faza 7): log wydajności /dashboard/* → storage/logs/dashboard-performance.log
# DASHBOARD_PERF_LOG=true
# DASHBOARD_PERF_SLOW_MS=500
# DASHBOARD_PERF_SLOW_QUERIES=25

# reszta bez zmian...
APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=sail
DB_PASSWORD=

# Secondary database connection for admpnedu (see config/database.php)
DB_ADMPNEDU_HOST=${DB_HOST}
DB_ADMPNEDU_PORT=${DB_PORT}
DB_ADMPNEDU_DATABASE=admpnedu
DB_ADMPNEDU_USERNAME=${DB_USERNAME}
DB_ADMPNEDU_PASSWORD=${DB_PASSWORD}

# Osobna baza analityczna. Produkcyjne hasło wpisuj wyłącznie w .env na serwerze.
DB_ANALYTICS_HOST=${DB_ADMPNEDU_HOST}
DB_ANALYTICS_PORT=${DB_ADMPNEDU_PORT}
DB_ANALYTICS_DATABASE=pne_analytics
DB_ANALYTICS_USERNAME=${DB_ADMPNEDU_USERNAME}
DB_ANALYTICS_PASSWORD=${DB_ADMPNEDU_PASSWORD}
ANALYTICS_ENABLED=true
ANALYTICS_DEFAULT_MODE=standard
ANALYTICS_SAMPLE_RATE=100
ANALYTICS_SESSION_COOKIE=pne_analytics_sid
ANALYTICS_SESSION_DAYS=30
ANALYTICS_ORDER_FORM_SESSION_COOKIE_PREFIX=pne_order_form_sid
ANALYTICS_ORDER_FORM_SESSION_HOURS=24
ANALYTICS_QUEUE_CONNECTION=redis
ANALYTICS_QUEUE=analytics
ANALYTICS_QUEUE_TRIES=2
ANALYTICS_QUEUE_TIMEOUT=30
ANALYTICS_RETENTION_RAW_EVENTS_DAYS=180
ANALYTICS_RETENTION_ORDER_FORM_SESSIONS_DAYS=365
ANALYTICS_RETENTION_AI_SAFE_EXPORTS_DAYS=365

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Produkcja (SeoHost, Faza 3 – mniej obciążenia MySQL):
# SESSION_DRIVER=file
# CACHE_STORE=file
# APP_DEBUG=false
# LOG_LEVEL=warning

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS=info@system.pnedu.pl
MAIL_FROM_NAME="Platforma Nowoczesnej Edukacji"
MAIL_REPLY_TO_ADDRESS=kontakt@pnedu.pl
MAIL_REPLY_TO_NAME="Platforma Nowoczesnej Edukacji"
MAIL_BRAND_PUBLIC_URL=https://pnedu.pl
MAIL_BRAND_PUBLIC_LABEL=www.pnedu.pl

# Produkcja SES (bez sekretów):
# MAIL_MAILER=ses
# MAIL_SES_CONFIGURATION_SET=pne-system

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-central-1
AWS_SNS_TOPIC_ARN=arn:aws:sns:eu-central-1:388786438877:ses-pne-system-events
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Komunikacja z panelem pneadm (server-to-server)
# PNEADM_API_URL=http://host.docker.internal:8083
# PNEADM_API_TOKEN=
# Token dla wywołań adm → pnedu (invalidacja cache oferty). Na dev może być ten sam co PNEADM_API_TOKEN.
# PNEDU_INTERNAL_API_TOKEN=
# CERT_REG_STATUS_CACHE_TTL=60
# CERT_REG_PAGE_CACHE_MAX_AGE=30
# CERT_REG_PAGE_CACHE_STALE=60
# CERT_REG_SESSION_DRIVER=redis

# GUS BIR/REGON lookup po NIP w formularzu zamówienia. Produkcyjny klucz wpisuj wyłącznie w .env.
# GUS_BIR_ENV=production
# GUS_BIR_USER_KEY=
# GUS_BIR_TIMEOUT=10

# Publiczny URL panelu pneadm (obrazki kursów / instruktorów z /storage)
# Lokalnie ustaw: http://adm.localhost:8083, na produkcji domyślnie https://adm.pnedu.pl
# PNEADM_PUBLIC_URL=https://adm.pnedu.pl
# Na produkcji domyślnie włączone: grafiki przez https://pnedu.pl/media/pneadm/… (bez cross-origin z adm)
# PNEADM_MEDIA_PROXY=true

# PayU płatności online
PAYU_SANDBOX=true
PAYU_POS_ID=
PAYU_SECOND_KEY=
PAYU_CLIENT_ID=
PAYU_CLIENT_SECRET=
# Opcjonalne klucze sandbox (gdy na prod włączasz tryb sandbox dla testów deweloperskich w panelu adm)
# PAYU_SANDBOX_POS_ID=
# PAYU_SANDBOX_SECOND_KEY=
# PAYU_SANDBOX_CLIENT_ID=
# PAYU_SANDBOX_CLIENT_SECRET=

# PayNow płatności online
# PAYNOW_SANDBOX=true
# PAYNOW_API_KEY=
# PAYNOW_SIGNATURE_KEY=
# PAYNOW_SANDBOX_API_KEY=
# PAYNOW_SANDBOX_SIGNATURE_KEY=

# Prefiks identyfikatora zamówień online (extOrderId). Na produkcji np. PNEdu# → PNEdu#1, PNEdu#2. Puste = PNEDU_1 (stary format).
# ONLINE_PAYMENT_ORDER_IDENT_PREFIX=PNEdu#
# Fragment środowiska: PNEDU_local_1 lub PNEdu#local_1 (gdy ustawiony prefiks). Na dev przy wspólnym POS: local
# ONLINE_PAYMENT_ORDER_IDENT_SEGMENT=local

# Sendy – zapis na listy (bezpłatne szkolenia, np. TIK w pracy NAUCZYCIELA)
SENDY_URL=
SENDY_API_KEY=
# Pole TEXT w Sendy (tag, np. „data”) — wartość RRRR-MM-DD przy zapisie z formularza zamówienia
SENDY_TRAINING_DATE_FIELD=data

# Google Tag Manager (agencja) – ładuje się tylko w produkcji.
# Aby wyłączyć całkowicie: ustaw pustą wartość: GOOGLE_TAG_MANAGER_ID=
# GOOGLE_TAG_MANAGER_ID=GTM-5ZQ4MM74

# Własne Google Analytics 4 – Measurement ID (format G-XXXXXXXXXX).
# Działa równolegle z GTM agencji; ten sam baner cookies (Consent Mode v2).
# GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

# Meta (Facebook) Pixel – ładuje się tylko w produkcji.
# Domyślnie używany jest pixel pnedu.pl (378657018971423).
# Aby wyłączyć całkowicie: ustaw pustą wartość: FACEBOOK_PIXEL_ID=
# FACEBOOK_PIXEL_ID=378657018971423

# Marketing – atrybucja kampanii (UTM + legacy fb), cookie 7 dni
MARKETING_ATTRIBUTION_DAYS=7

# Lejek — opt-out dla zespołu (cookie po jednorazowym wejściu w link z tokenem)
# Przykład włączenia: https://pnedu.pl/?pne_skip_funnel=1&token=TWÓJ_SEKRET
# Wyłączenie liczenia: ?pne_skip_funnel=0&token=TWÓJ_SEKRET
# MARKETING_FUNNEL_SKIP_TOKEN=
# MARKETING_FUNNEL_SKIP_COOKIE_DAYS=365
# MARKETING_FUNNEL_SKIP_COOKIE_DOMAIN=.pnedu.pl

