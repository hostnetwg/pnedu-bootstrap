<IfModule mod_rewrite.c>
    <IfModule mod_negotiation.c>
        Options -MultiViews -Indexes
    </IfModule>

    RewriteEngine On

    # Krótkie linki kampanii: /l/{campaign_code} → l.php (działa także przy starym route:cache)
    RewriteRule ^l/([A-Za-z0-9._-]+)$ l.php?code=$1 [L,QSA]

    # Handle Authorization Header
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # Handle X-XSRF-Token Header
    RewriteCond %{HTTP:x-xsrf-token} .
    RewriteRule .* - [E=HTTP_X_XSRF_TOKEN:%{HTTP:X-XSRF-Token}]

    # Redirect Trailing Slashes If Not A Folder...
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} (.+)/$
    RewriteRule ^ %1 [L,R=301]

    # Send Requests To Front Controller...
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^ index.php [L]
</IfModule>

# Faza 3: długi cache plików Vite (hash w nazwie → bezpieczne immutable)
# Faza 6: cache statycznych obrazów i favicon (30 dni)
<IfModule mod_headers.c>
    SetEnvIf Request_URI "^/build/assets/" vite_build_asset=1
    Header set Cache-Control "public, max-age=31536000, immutable" env=vite_build_asset

    SetEnvIf Request_URI "^/(images|logo-pne\.png|favicon|apple-touch-icon|site\.webmanifest)" static_public_asset=1
    Header set Cache-Control "public, max-age=2592000" env=static_public_asset
</IfModule>
